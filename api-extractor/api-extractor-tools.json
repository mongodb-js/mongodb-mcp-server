{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",
  "extends": "../api-extractor.json",

  "mainEntryPointFilePath": "<projectFolder>/dist/esm/tools/index.d.ts",

  "bundledPackages": [
    "@mongodb-js/mcp-core",
    "@mongodb-js/mcp-http-runners",
    "@mongodb-js/mcp-tools-mongodb",
    "@mongodb-js/mcp-atlas-api-client",
    "@mongodb-js/mcp-atlas-telemetry",
    "@mongodb-js/mcp-logging",
    "@mongodb-js/mcp-metrics",
    "@mongodb-js/mcp-types",
    "@mongodb-js/mcp-ui"
  ],

  "apiReport": {
    "enabled": true,
    "reportFolder": "<projectFolder>/api-extractor/reports/",
    "reportFileName": "tools"
  },

  "docModel": {
    "enabled": false
  }
}
