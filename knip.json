{
  "workspaces": {
    ".": {
      "entry": [
        "src/index.ts!",
        "src/lib.ts!",
        "src/web.ts!",
        "src/tools/index.ts!",
        "tests/**/*.ts",
        "!tests/browser/**",
        "scripts/**/*.ts",
        "eslint-rules/*.js"
      ],
      "ignore": ["tests/integration/fixtures/curl.mjs", "tests/vitest.d.ts"],
      "ignoreDependencies": [
        "@mongodb-js/atlas-local",
        "@emotion/css",
        "@leafygreen-ui/table"
      ]
    },
    "tests/browser": {
      "entry": [
        "tests/**/*.ts",
        "polyfills/**/*.ts",
        "utils/**/*.ts",
        "vitest.config.ts",
        "setup.ts"
      ]
    }
  },
  "ignoreExportsUsedInFile": true
}
