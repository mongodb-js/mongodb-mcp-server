{
  "name": "mongodb-mcp-server-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "start": "pnpm --filter mongodb-mcp-server start",
    "start:stdio": "pnpm --filter mongodb-mcp-server start:stdio",
    "start:setup": "pnpm --filter mongodb-mcp-server start:setup",
    "prepare": "husky",
    "build:update-package-version": "pnpm --filter @mongodb-js/mcp-scripts update:package-version",
    "prebuild:mcpb": "pnpm run build",
    "build:mcpb": "pnpm --filter mongodb-mcp-server build:mcpb",
    "build": "pnpm --filter './packages/*' --filter '!./packages/*-tests' --filter '!./packages/test-utils' -r run build",
    "inspect": "pnpm --filter mongodb-mcp-server inspect",
    "prettier": "prettier",
    "check": "concurrently \"pnpm run check:types\" \"pnpm run check:style\" \"pnpm run check:api\"",
    "check:types": "pnpm run -r --parallel check",
    "check:style": "concurrently \"pnpm run check:lint\" \"pnpm run check:format\" \"pnpm run check:dependencies\"",
    "check:api": "pnpm run -r --parallel check:api",
    "check:lint": "eslint .",
    "check:dependencies": "knip --no-config-hints",
    "check:format": "prettier -c .",
    "update:api": "pnpm run build && pnpm run -r --parallel update:api",
    "fix": "pnpm run fix:lint && pnpm run reformat",
    "fix:lint": "eslint . --fix",
    "reformat": "prettier --write .",
    "generate": "pnpm run generate:api && pnpm run generate:arguments && pnpm run generate:ui",
    "generate:ui": "pnpm --filter @mongodb-js/mcp-scripts generate:ui",
    "generate:api": "pnpm --filter @mongodb-js/mcp-scripts generate:api",
    "generate:arguments": "pnpm --filter @mongodb-js/mcp-scripts generate",
    "generate:release-notes": "pnpm --filter @mongodb-js/mcp-scripts generate:release-notes",
    "pretest": "pnpm run build",
    "test": "vitest --project eslint-rules --project unit-and-integration --coverage --run",
    "test:accuracy": "pnpm --filter @mongodb-js/mcp-accuracy-tests test",
    "test:browser": "pnpm --filter @mongodb-js/mcp-browser-tests test",
    "test:long-running-tests": "vitest --project long-running-tests --coverage",
    "test:local": "SKIP_ATLAS_INTEGRATION_TESTS=true SKIP_ATLAS_LOCAL_TESTS=true pnpm run test",
    "prevalidate:mcpb": "pnpm run build",
    "validate:mcpb": "pnpm --filter mongodb-mcp-server validate:mcpb",
    "atlas:cleanup": "vitest --project atlas-cleanup",
    "eval:db-start": "pnpm --filter @mongodb-js/mcp-eval-tests eval:db-start",
    "eval:db-stop": "pnpm --filter @mongodb-js/mcp-eval-tests eval:db-stop",
    "eval:run": "pnpm --filter @mongodb-js/mcp-eval-tests eval:run",
    "eval:debug": "pnpm --filter @mongodb-js/mcp-eval-tests eval:debug",
    "eval:ci:run": "pnpm --filter @mongodb-js/mcp-eval-tests eval:ci:run",
    "eval:generate-schemas": "pnpm --filter @mongodb-js/mcp-eval-tests eval:generate-schemas",
    "eval:bundle": "pnpm --filter @mongodb-js/mcp-eval-tests eval:bundle",
    "eval:serve": "pnpm --filter @mongodb-js/mcp-eval-tests eval:serve",
    "eval:push": "pnpm --filter @mongodb-js/mcp-eval-tests eval:push"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lg-mcp/embeddable-uis": "^0.1.0",
    "@lg-mcp/hooks": "^0.2.0",
    "@microsoft/api-extractor": "^7.58.7",
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@mongodb-js/oidc-mock-provider": "^0.13.7",
    "@redocly/cli": "^2.29.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "ai": "^6.0.175",
    "braintrust": "^3.20.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "knip": "^6.16.1",
    "prettier": "^3.8.3",
    "proper-lockfile": "^4.1.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "semver": "^7.7.4",
    "simple-git": "^3.36.0",
    "testcontainers": "^12.0.3",
    "tsx": "^4.20.5",
    "type-fest": "^5.6.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.2",
    "uuid": "^14.0.1",
    "vite": "^8.0.16",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >= 24.0.0"
  }
}
