{
  "name": "mongodb-mcp-server-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "start": "pnpm --filter mongodb-mcp-server start",
    "start:stdio": "pnpm --filter mongodb-mcp-server start:stdio",
    "start:setup": "pnpm --filter mongodb-mcp-server start:setup",
    "prepare": "husky",
    "build:update-package-version": "pnpm --filter @mongodb-js/mcp-scripts update:package-version",
    "prebuild:mcpb": "pnpm run build",
    "build:mcpb": "pnpm --filter mongodb-mcp-server build:mcpb",
    "build": "pnpm run -r compile",
    "inspect": "pnpm --filter mongodb-mcp-server inspect",
    "prettier": "prettier",
    "check": "concurrently \"pnpm run build\" \"pnpm run check:types\" \"pnpm run check:lint\" \"pnpm run check:format\" \"pnpm run check:dependencies\" && pnpm run check:api",
    "check:api": "pnpm --filter mongodb-mcp-server check:api && pnpm --filter @mongodb-js/mcp-ui check:api",
    "check:lint": "eslint .",
    "check:dependencies": "knip && knip --strict",
    "check:format": "prettier -c .",
    "check:types": "tsc --noEmit --project tsconfig.json",
    "update:api": "pnpm run build && pnpm --filter mongodb-mcp-server update:api && pnpm --filter @mongodb-js/mcp-ui update:api",
    "fix": "pnpm run fix:lint && pnpm run reformat",
    "fix:lint": "eslint . --fix",
    "reformat": "prettier --write .",
    "generate": "pnpm run generate:api && pnpm run generate:arguments && pnpm run generate:ui",
    "generate:ui": "pnpm --filter @mongodb-js/mcp-scripts generate:ui",
    "generate:api": "pnpm --filter @mongodb-js/mcp-scripts generate:api",
    "generate:arguments": "pnpm --filter @mongodb-js/mcp-scripts generate",
    "generate:release-notes": "pnpm --filter @mongodb-js/mcp-scripts generate:release-notes",
    "pretest": "pnpm run build",
    "test": "vitest --project eslint-rules --project unit-and-integration --coverage --run",
    "test:accuracy": "pnpm --filter @mongodb-js/mcp-accuracy-tests test",
    "test:browser": "pnpm --filter browser test",
    "test:long-running-tests": "vitest --project long-running-tests --coverage",
    "test:local": "SKIP_ATLAS_INTEGRATION_TESTS=true SKIP_ATLAS_LOCAL_TESTS=true pnpm run test",
    "prevalidate:mcpb": "pnpm run build",
    "validate:mcpb": "pnpm --filter mongodb-mcp-server validate:mcpb",
    "atlas:cleanup": "vitest --project atlas-cleanup"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/azure": "^3.0.62",
    "@ai-sdk/google": "^3.0.67",
    "@ai-sdk/mcp": "^1.0.40",
    "@ai-sdk/openai": "^3.0.61",
    "@anthropic-ai/mcpb": "2.1.2",
    "@emotion/css": "^11.13.5",
    "@eslint/js": "^10.0.1",
    "@lg-mcp/embeddable-uis": "^0.1.0",
    "@lg-mcp/hooks": "^0.2.0",
    "@microsoft/api-extractor": "^7.58.7",
    "@modelcontextprotocol/inspector": "^0.21.2",
    "@mongodb-js/oidc-mock-provider": "^0.13.7",
    "@redocly/cli": "^2.29.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/express": "^5.0.0",
    "@types/node": "^25.6.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/semver": "^7.7.0",
    "@types/yargs-parser": "^21.0.3",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "ai": "^6.0.175",
    "concurrently": "^9.2.1",
    "duplexpair": "^1.0.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.4.1",
    "oauth4webapi": "^3.8.5",
    "openapi-typescript": "^7.13.0",
    "openapi-typescript-helpers": "^0.1.0",
    "prettier": "^3.8.1",
    "proper-lockfile": "^4.1.2",
    "semver": "^7.7.4",
    "simple-git": "^3.36.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^4.1.5",
    "yaml": "^2.8.1"
  },
  "pnpm": {
    "overrides": {
      "mongodb": "^7.1.1",
      "kerberos": "^7.0.0",
      "bson": "^7.2.0",
      "zod": "^4.4.2"
    }
  },
  "overrides": {
    "mongodb": "^7.1.1",
    "kerberos": "^7.0.0",
    "bson": "^7.2.0",
    "zod": "^4.4.2"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >= 24.0.0"
  }
}
