{
  "name": "@mongodb-js/mcp-setup",
  "version": "1.11.0-prerelease.3",
  "type": "module",
  "description": "Setup wizard and configuration for MongoDB MCP server",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "test": "vitest --run",
    "check": "tsc --build tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.0.2",
    "@inquirer/select": "^5.1.3",
    "@mongodb-js/mcp-atlas-api-client": "workspace:*",
    "@mongodb-js/mcp-atlas-telemetry": "workspace:*",
    "@mongodb-js/mcp-core": "workspace:*",
    "@mongodb-js/mcp-tools-atlas-local": "workspace:*",
    "@mongodb-js/mcp-tools-mongodb": "workspace:*",
    "@mongosh/service-provider-node-driver": "^5.0.2",
    "chalk": "^5.6.2",
    "jsonc-parser": "^3.3.1",
    "mongodb-redact": "^1.4.6",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@mongodb-js/mcp-types": "workspace:*",
    "@mongodb-js/mcp-cli": "workspace:*",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.7.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5"
  }
}
