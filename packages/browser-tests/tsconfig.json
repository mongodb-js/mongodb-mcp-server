{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "paths": {
      "@mongodb-js/devtools-proxy-support/proxy-options": [
        "./polyfills/empty.ts"
      ]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
