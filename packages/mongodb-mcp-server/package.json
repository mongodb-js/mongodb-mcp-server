{
  "name": "mongodb-mcp-server",
  "description": "MongoDB Model Context Protocol Server",
  "version": "1.11.0-prerelease.3",
  "type": "module",
  "mcpName": "io.github.mongodb-js/mongodb-mcp-server",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/lib.d.ts",
        "default": "./dist/esm/lib.js"
      },
      "require": {
        "types": "./dist/cjs/lib.d.ts",
        "default": "./dist/cjs/lib.js"
      }
    },
    "./web": {
      "import": {
        "types": "./dist/esm/web.d.ts",
        "default": "./dist/esm/web.js"
      },
      "require": {
        "types": "./dist/cjs/web.d.ts",
        "default": "./dist/cjs/web.js"
      }
    },
    "./tools": {
      "import": {
        "types": "./dist/esm/tools/index.d.ts",
        "default": "./dist/esm/tools/index.js"
      },
      "require": {
        "types": "./dist/cjs/tools/index.d.ts",
        "default": "./dist/cjs/tools/index.js"
      }
    },
    "./test-helpers": {
      "import": {
        "types": "./dist/esm/test-helpers/index.d.ts",
        "default": "./dist/esm/test-helpers/index.js"
      },
      "require": {
        "types": "./dist/cjs/test-helpers/index.d.ts",
        "default": "./dist/cjs/test-helpers/index.js"
      }
    }
  },
  "main": "./dist/cjs/lib.js",
  "types": "./dist/cjs/lib.d.ts",
  "author": "MongoDB <info@mongodb.com>",
  "homepage": "https://github.com/mongodb-js/mongodb-mcp-server",
  "repository": {
    "url": "https://github.com/mongodb-js/mongodb-mcp-server.git"
  },
  "bin": {
    "mongodb-mcp-server": "dist/esm/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node dist/index.js --transport http --loggers 'stderr, mcp'",
    "start:stdio": "node dist/index.js --transport stdio --loggers 'stderr, mcp'",
    "start:setup": "pnpm run compile && node dist/index.js setup",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "compile": "concurrently \"pnpm run build:esm\" \"pnpm run build:cjs\" && pnpm run build:universal-package",
    "build:universal-package": "tsx scripts/createUniversalPackage.ts",
    "inspect": "pnpm run compile && mcp-inspector -- dist/esm/index.js",
    "check:types": "tsc --noEmit --project tsconfig.json",
    "check:api-report": "concurrently \"api-extractor run --config api-extractor.json\" \"api-extractor run --config api-extractor/api-extractor-web.json\"",
    "check:api": "pnpm run check:api-report || (printf \"\\nPublic API check failed. If you intended to change the public API, run:\\n\\n  pnpm run update:api\\n\" && exit 1)",
    "update:api": "concurrently \"api-extractor run --local --config api-extractor.json\" \"api-extractor run --local --config api-extractor/api-extractor-web.json\" \"api-extractor run --local --config api-extractor/api-extractor-tools.json\"",
    "build:mcpb": "tsx scripts/createMcpb.ts",
    "validate:mcpb": "tsx scripts/createMcpb.ts --validate-only"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.7",
    "@mongodb-js/mcp-test-utils": "workspace:*",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.5",
    "type-fest": "^5.6.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mongodb-js/device-id": "^0.4.11",
    "@mongodb-js/mcp-atlas-api-client": "workspace:*",
    "@mongodb-js/mcp-atlas-telemetry": "workspace:*",
    "@mongodb-js/mcp-cli": "workspace:*",
    "@mongodb-js/mcp-core": "workspace:*",
    "@mongodb-js/mcp-http-runners": "workspace:*",
    "@mongodb-js/mcp-logging": "workspace:*",
    "@mongodb-js/mcp-metrics": "workspace:*",
    "@mongodb-js/mcp-setup": "workspace:*",
    "@mongodb-js/mcp-tools-assistant": "workspace:*",
    "@mongodb-js/mcp-tools-atlas": "workspace:*",
    "@mongodb-js/mcp-tools-atlas-local": "workspace:*",
    "@mongodb-js/mcp-tools-mongodb": "workspace:*",
    "@mongodb-js/mcp-types": "workspace:*",
    "@mongodb-js/mcp-ui": "workspace:*",
    "bson": "^7.2.0",
    "mongodb": "^7.1.1",
    "@mongosh/service-provider-node-driver": "^5.0.2",
    "mongodb-redact": "^1.4.6",
    "mongodb-schema": "^12.7.0",
    "node-machine-id": "1.1.12",
    "oauth4webapi": "^3.8.6",
    "openapi-fetch": "^0.17.0",
    "semver": "^7.7.4",
    "ts-levenshtein": "^1.0.7",
    "zod": "^4.4.2"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >= 24.0.0"
  },
  "optionalDependencies": {
    "@mongodb-js/atlas-local": "^1.3.0",
    "kerberos": "^7.0.0"
  }
}
