{
  "name": "@mongodb-mcp/transport",
  "version": "1.0.0",
  "description": "Transport implementations for MongoDB MCP Server",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && tsc --project tsconfig.cjs.json",
    "check:types": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mongodb-mcp/logging": "workspace:*",
    "@mongodb-mcp/monitoring": "workspace:*",
    "express": "^5.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.2"
  },
  "license": "Apache-2.0"
}
