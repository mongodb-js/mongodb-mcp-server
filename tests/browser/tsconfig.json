{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "paths": {
      "mongodb-mcp-server": ["../../packages/mongodb-mcp-server/src/lib"],
      "mongodb-mcp-server/web": ["../../packages/mongodb-mcp-server/src/web"],
      "ts-levenshtein": [
        "../../packages/cli/node_modules/ts-levenshtein/dist/index.d.mts"
      ]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
